# ============================================================
# Bilibili RAG —— 环境变量
# ------------------------------------------------------------
# 配置层级(由低到高,后者覆盖前者):
#   1. Pydantic 字段默认值
#   2. app/config/default.yaml
#   3. app/config/config.yaml             ← team-shared overrides (committed, optional)
#   4. app/config/local.yaml              ← personal overrides (.gitignore)
#   5. 环境变量(本文件)                   ← highest priority
#
# 命名规则:env 变量用 `双下划线` 嵌套到 YAML 字段
#   MINIO__ACCESS_KEY → minio.access_key
#   RDBMS__POOL_SIZE  → rdbms.pool_size
#
# ⚠️ 本文件只列 [敏感字段 + 必要的 SDK 直读变量]
#    所有非敏感配置(端口/超时/池大小/模型名等)请去 YAML 改,不要往这里塞
# ============================================================

# ============================================================
# 敏感字段(走 env / K8s Secret,YAML 永远不写)
# ============================================================

# ------------------------------------------------------------
# LLM —— 兼容 OpenAI 协议(默认走阿里云 DashScope)
# ------------------------------------------------------------
# 对应 YAML: llm.api_key
LLM__API_KEY=
# 如需覆盖 base_url / model,改 YAML 即可,无需在此重复

# ------------------------------------------------------------
# Session —— FastAPI session 签名密钥
# ------------------------------------------------------------
# 对应 YAML: session.secret
# 生成方式:python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION__SECRET=

# ------------------------------------------------------------
# 用户 API Key 加密密钥(32 字节,base64 编码)
# ------------------------------------------------------------
# 对应 YAML: security.api_key_encryption_key
# 生成方式:python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# ⚠️ 部署后不要修改此密钥,否则所有已存储的用户 API Key 将无法解密
SECURITY__API_KEY_ENCRYPTION_KEY=

# ============================================================
# 可选基础设施敏感字段(只在 enabled=true 时需要)
# ============================================================

# ------------------------------------------------------------
# MongoDB(默认 enabled=false,启用后填)
# ------------------------------------------------------------
# 完整 URI(含密码)走这一项,YAML 里只列 host/port/db
# MONGO__URI=mongodb://user:pass@host:27017/bilirag

# ------------------------------------------------------------
# Redis(默认 enabled=false,启用后填)
# ------------------------------------------------------------
# REDIS__URL=redis://:password@host:6379/0
# REDIS__PASSWORD=

# ------------------------------------------------------------
# MinIO(默认 enabled=false,启用后填)
# ------------------------------------------------------------
# MINIO__ACCESS_KEY=
# MINIO__SECRET_KEY=

# ------------------------------------------------------------
# RabbitMQ(默认 enabled=false,启用后填)
# ------------------------------------------------------------
# MQ__RABBITMQ_URL=amqp://user:pass@host:5672/

# ------------------------------------------------------------
# RDBMS —— 生产环境的真实连接串(连接池参数走 YAML)
# ------------------------------------------------------------
# 对应 YAML: rdbms.url(开发期 sqlite,生产期 PostgreSQL)
# RDBMS__URL=postgresql+asyncpg://user:pass@host:5432/bilirag

# ============================================================
# LangSmith —— LangChain SDK 直读以下变量(非我们 config 命名空间)
# ------------------------------------------------------------
# 启用 trace 必须三件套同时设置:
#   LANGCHAIN_TRACING_V2=true / LANGSMITH_TRACING=true / LANGSMITH_API_KEY=...
# 对应 YAML: langsmith.enabled(我们的代码用它判断是否包装 trace)
# ============================================================
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bilibili-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ============================================================
# 已废弃 —— 这些字段已迁移到 app/config/*.yaml
# ------------------------------------------------------------
# DASHSCOPE_API_KEY      → LLM__API_KEY(本文件)
# OPENAI_API_KEY         → LLM__API_KEY(本文件)
# OPENAI_BASE_URL        → llm.base_url(default.yaml)
# LLM_MODEL              → llm.model(default.yaml)
# EMBEDDING_MODEL        → embedding.model(default.yaml)
# EVAL_LLM_MODEL         → llm.eval_model(default.yaml)
# AGENTIC_RAG_TOP_K      → agentic.top_k(default.yaml)
# AGENTIC_RAG_MAX_HOPS   → agentic.max_hops(default.yaml)
# DASHSCOPE_BASE_URL     → asr.base_url(default.yaml)
# ASR_MODEL              → asr.model(default.yaml)
# ASR_TIMEOUT            → asr.timeout(default.yaml)
# ASR_MODEL_LOCAL        → asr.model_local(default.yaml)
# ASR_INPUT_FORMAT       → asr.input_format(default.yaml)
# APP_HOST               → server.host(default.yaml)
# APP_PORT               → server.port(default.yaml)
# DEBUG                  → app.debug(config.yaml)
# DATABASE_URL           → rdbms.url(default.yaml,生产走 RDBMS__URL env)
# CHROMA_PERSIST_DIRECTORY → chroma.persist_directory(default.yaml)
# CHUNK_TARGET_SIZE      → chunk.target_size(default.yaml)
# CHUNK_MIN_SIZE         → chunk.min_size(default.yaml)
# CHUNK_MAX_SIZE         → chunk.max_size(default.yaml)
# CHUNK_OVERLAP          → chunk.overlap(default.yaml)
# EMBEDDING_VERSION      → embedding.version(default.yaml)
# API_KEY_ENCRYPTION_KEY → SECURITY__API_KEY_ENCRYPTION_KEY(本文件)
# ============================================================
