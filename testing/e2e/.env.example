# Copy to .env and fill in real values before running tests

# Frontend URL (Next.js dev server)
BASE_URL=http://localhost:3000

# Backend URL (FastAPI)
API_BASE_URL=http://localhost:8000

# Login method: "password" (preferred for automation) or "storage_state"
LOGIN_METHOD=password

# Email/password login (test account)
TEST_EMAIL=test@example.com
TEST_PASSWORD=change-me

# Storage state file (used when LOGIN_METHOD=storage_state)
# Generate by: playwright codegen --save-storage=auth.json
STORAGE_STATE=data/auth.json

# Test folder ids (comma-separated) - small test folder to avoid long sync
TEST_FOLDER_IDS=1

# Timeout overrides (ms)
DEFAULT_TIMEOUT=15000
NAV_TIMEOUT=30000
